# ============================================================================
# DOME 4.0 Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git — it contains secrets.
# ============================================================================

# ── DOME Core ──────────────────────────────────────────────────────────────
DOME_CORE_ROOT=D:\DOME_CORE
DOME_VERSION=4.0
DOME_ENVIRONMENT=home

# ── Supabase (Personal Account) ───────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API
DOME_SUPABASE_URL=https://your-project-id.supabase.co
DOME_SUPABASE_KEY=your-anon-key-here

# ── Embedding Provider (pick one) ─────────────────────────────────────────
# Option A: OpenAI (recommended — text-embedding-3-small, 1536 dims)
OPENAI_API_KEY=sk-your-key-here

# Option B: Google Gemini (free tier available)
# GOOGLE_API_KEY=your-gemini-key-here

# ── Agent Identity ─────────────────────────────────────────────────────────
AGENT_ID=global_brain
WORKSPACE_ID=c:\Users\robis\Agentic_workflows\Global_brain

# ── Optional: Hostname Detection ──────────────────────────────────────────
# Comma-separated list of hostnames that should be detected as "home"
# DOME_HOME_HOSTNAMES=DESKTOP-ROBIS,HOME-PC
