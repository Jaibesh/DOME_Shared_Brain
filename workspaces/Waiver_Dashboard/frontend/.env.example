# Vercel Environment Variables
# Copy to .env.local for local development or set in Vercel Dashboard for production

# Backend API URL (Railway) — MUST include https:// protocol
VITE_API_BASE_URL=https://epic-waiver-dashboard-production.up.railway.app

# WebSocket URL (Railway) — MUST include wss:// protocol  
VITE_WS_BASE_URL=wss://epic-waiver-dashboard-production.up.railway.app
